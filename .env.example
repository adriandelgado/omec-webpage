# Local development defaults to a SQLite/libSQL file with no secrets required.
DATABASE_URL="file:local.db"

# Only set this for a remote Turso/libSQL database.
DATABASE_AUTH_TOKEN=""

# Production Cloudflare Worker secret/var examples:
# DATABASE_URL="libsql://your-database-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
